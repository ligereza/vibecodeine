# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
*.egg-info/
dist/
build/

# Env / secrets
.env
*.key
*.pem
credentials.json
token.json

# OS
.DS_Store
Thumbs.db

# Airdrop
_airdrop/
_airdrop_backups/

# Jobs de trabajo (NO commitear, excepto _template)
jobs/*
!jobs/_template/
!jobs/_template/*
!jobs/.gitkeep

# === Media de proyectos (NO ignorar imágenes del repo/docs) ===
# Solo ignorar outputs de proyectos flyer
projects/flyer_eventos/*/input/*
projects/flyer_eventos/*/working/*
projects/flyer_eventos/*/exports/*
projects/flyer_eventos/*/refs/*
!projects/flyer_eventos/*/*/.gitkeep

# Data generada
data/*.json
context/DAILY.md
context/PIPELINE_RESULT.md
context/dashboard.html

# Temporales
*.tmp
*.temp
tmp_*/
ig_*/

# Carpetas de descarga de Instagram con ruta de Windows (no commitear)
C：*/
*ig_*/


# Proyectos de piezas generados desde jobs (fecha-prefijo)
projects/piezas_vectoriales/20*/

# Piezas vectoriales - salidas generadas
projects/piezas_vectoriales/*/salida_generada/
projects/piezas_vectoriales/*/02_editables_svg/
projects/piezas_vectoriales/*/03_final_vectorizado_svg/
projects/piezas_vectoriales/*/04_preview/
projects/piezas_vectoriales/*/05_exports/

