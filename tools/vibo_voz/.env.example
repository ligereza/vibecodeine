# Copia este archivo como  .env  y rellena tus valores.
# El archivo .env esta en .gitignore: NUNCA se sube al repo.

# 1) Key gratis de Google AI Studio -> https://aistudio.google.com/apikey
GEMINI_API_KEY=pega_aqui_tu_key_de_gemini

# 2) Token de GitHub SOLO LECTURA (fine-grained).
#    github.com > Settings > Developer settings > Personal access tokens >
#    Fine-grained tokens > Generate new token:
#      - Resource owner: ligereza
#      - Repository access: Only select repositories -> vibecodeine
#      - Permissions (Repository): Contents = Read-only, Issues = Read-only,
#        Metadata = Read-only.  NADA de write.
GITHUB_TOKEN=pega_aqui_tu_token_read_only

# 3) Repo que se va a consultar
GITHUB_OWNER=ligereza
GITHUB_REPO=vibecodeine

# 4) (Puente a Claude local) comando del CLI de Claude, carpeta del proyecto de
#    Unreal, y modo de permisos con que corren los agentes headless.
#    acceptEdits = editan sin preguntar; pon 'plan' si quieres revisar antes.
#    CLAUDE_CMD: normalmente 'claude' basta (se resuelve solo, incluso claude.cmd
#    de npm). Si no lo encuentra, pon la ruta completa, ej:
#    C:\Users\issvk\AppData\Roaming\npm\claude.cmd
CLAUDE_CMD=claude
VIBO_UNREAL_DIR=C:\ARICA\MYRA
CLAUDE_PERMISSION_MODE=acceptEdits
# Ahorro (opcional):
#   CLAUDE_MODEL=haiku       -> secretario con modelo barato para tareas simples
#   CLAUDE_CONTINUE=1        -> reutiliza contexto de la orden anterior (menos recarga)
CLAUDE_MODEL=
CLAUDE_CONTINUE=

# --- Opcionales (valores por defecto razonables) ---
# Modelo Live de Gemini. Default estable en AI Studio. Si da error "not found /
# not supported for bidiGenerateContent", corre  py list_models.py  y pega aqui
# uno de los que salgan (sin el prefijo 'models/').
VIBO_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
# Voces (prebuilt de Gemini): Kore, Puck, Charon, Aoede, Fenrir...
VIBO_VOICE=Kore    # cara publica VIBO (personal/general)
REDU_VOICE=Charon  # modo profesional REDU (trabajo ONG, confidencial)
# Tecla GLOBAL para hablar (mantener presionada mientras hablas). Funciona en todo
# el sistema aunque no estes en la ventana. Por defecto F8 para no chocar con la
# escritura normal. Otras: f9, f10, ctrl_r (Ctrl derecho), space (NO recomendada).
VIBO_PTT_KEY=f8
