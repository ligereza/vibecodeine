<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0"
    ExtensionBundleId="com.vibo.adobepanel"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="Vibo Adobe Panel"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.vibo.adobepanel.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="ILST" Version="[24.0,99.9]"/>
      <Host Name="PHXS" Version="[24.0,99.9]"/>
      <Host Name="PHSP" Version="[24.0,99.9]"/>
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.vibo.adobepanel.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Vibo Adobe Panel</Menu>
          <Geometry>
            <Size><Height>440</Height><Width>320</Width></Size>
            <MinSize><Height>260</Height><Width>240</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
