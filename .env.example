# .env.example - flujo
# Copia a .env (gitignored) y rellena con TUS claves reales. NUNCA commitees .env.
# Todas son opcionales: solo pon las de los proveedores que uses.

# --- Claude / Anthropic (arquitecto, revisor final) ---
ANTHROPIC_API_KEY=

# --- Qwen (editor barato via DashScope) ---
# Usa una de las dos segun tu region/SDK; DASHSCOPE es el nombre litellm.
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# --- NVIDIA NIM (alternativa barata: Qwen/DeepSeek/Nemotron) ---
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEY=

# --- OpenRouter (router / fallback de modelos) ---
OPENROUTER_API_KEY=

# --- Gemini (voz tools/vibo_voz + vision src/flujo/eventos flyer->productora) ---
GEMINI_API_KEY=
GEMINI_API_KEY_2=          # fallback opcional, otra cuenta/proyecto
# GITHUB_TOKEN=            # read-only, solo para tools/vibo_voz
